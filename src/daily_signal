name: NHL Betting Signal

on:
  schedule:
    - cron: '0 13 * * *'   # 9h ET — backtest + signal matin
    - cron: '0 17 * * *'   # 13h ET — mise a jour midday
    - cron: '0 22 * * *'   # 18h ET — signal soir avant matchs
  workflow_dispatch:

permissions:
  contents: write

jobs:
  generate-signal:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Installer dependances
        run: pip install -r requirements.txt

      - name: Backtest hier + generer signal
        env:
          ODDS_API_KEY: ${{ secrets.ODDS_API_KEY }}
        run: |
          cd src
          echo "=== BACKTEST HIER ==="
          python backtester.py ../docs/signal.json || echo "Backtest skip (pas de signal hier)"
          echo "=== SIGNAL AUJOURD'HUI ==="
          python signal.py

      - name: Commit et push
        run: |
          git config --global user.name "NHL Bot"
          git config --global user.email "bot@nhl.local"
          git add docs/
          git diff --staged --quiet || git commit -m "Signal + backtest $(date +'%Y-%m-%d %H:%M')"
          git push
